# golangci-lint configuration for %%PROJECT_NAME%%
#
# Generated by leap scaffolder.
# Run: golangci-lint run ./...
# Required version: golangci-lint >= 1.62.0
#
# CI invocation: golangci-lint run --new-from-rev=HEAD~1 --timeout=5m ./...

version: "2"

linters:
  default: none
  enable:
    # Dead code / unused symbols
    - unused
    - deadcode
    - unparam
    - ineffassign
    # Static analysis
    - staticcheck
    - revive
    # Security
    - gosec
    # Error handling
    - errcheck

linters-settings:
  revive:
    rules:
      - name: exported
        severity: warning
        disabled: false
      - name: var-naming
        severity: warning
        disabled: false
      - name: package-comments
        severity: warning
        disabled: false
      - name: error-return
        severity: error
        disabled: false
      - name: error-strings
        severity: error
        disabled: false
      - name: error-naming
        severity: error
        disabled: false
      - name: if-return
        severity: warning
        disabled: false
      - name: increment-decrement
        severity: warning
        disabled: false
      - name: unused-parameter
        severity: warning
        disabled: false
      - name: unreachable-code
        severity: error
        disabled: false

  gosec:
    severity: medium
    confidence: medium
    excludes:
      # G104: Errors unhandled — handled by errcheck
      - G104

  staticcheck:
    checks:
      - all
      - "-SA1019" # deprecated usage warnings are noise during early dev

  errcheck:
    # Check type assertions (x.(T)) as well
    check-type-assertions: true
    # Check blank identifier assignments e.g. x, _ = something()
    check-blank: true

  unused:
    # Consider exported symbols (fields, funcs) as used even if only in tests
    field-writes-are-uses: true
    post-statements-are-reads: true

issues:
  exclude-rules:
    # Test files: relax errcheck and gosec
    - path: "_test\\.go"
      linters:
        - errcheck
        - gosec
    # Generated files
    - path: ".*\\.gen\\.go"
      linters:
        - all
  # Show all issues, not just the first N per linter
  max-issues-per-linter: 0
  max-same-issues: 0
  # Don't exclude common false-positives by default
  exclude-use-default: false

run:
  timeout: 5m
  go: "1.23"
