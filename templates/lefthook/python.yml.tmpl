# lefthook.yml — client-side pre-commit hooks for Python projects
#
# Generated by leap scaffolder for %%PROJECT_NAME%%.
#
# FRAMING: These hooks are a LATENCY OPTIMIZATION, not a security control.
# They catch issues before push so the CI rejection loop is shorter.
# The same rules re-run in CI. Bypassing lefthook with --no-verify does NOT
# skip enforcement — it merely delays failure to push time.
#
# Hook budget: every hook must complete in <10 s on a typical single-file change.
# Slow checks belong in CI, not pre-commit.

pre-commit:
  parallel: true
  commands:
    ruff-format:
      # Run ruff format on staged Python files only.
      # lefthook skips this command when no files match the glob.
      glob: "*.py"
      run: ruff format {staged_files}

    ruff-lint:
      # Run ruff lint on staged Python files only.
      # lefthook skips this command when no files match the glob.
      glob: "*.py"
      run: ruff check {staged_files}

    forbidden-tokens:
      # Scan staged files for forbidden tokens (.only, .skip, etc.).
      # A waiver (ISSUE-### on adjacent line + docs/waivers.yaml entry) is required
      # to commit any of these tokens. CI enforces the same rule server-side.
      run: ops/checks/forbidden-tokens.sh {staged_files}

    gitleaks:
      # Secret detection on staged files.
      # Requires gitleaks >= 8.x to be installed on the developer machine.
      # Install: https://github.com/gitleaks/gitleaks#installation
      # If gitleaks is not installed this hook skips with a warning — CI
      # runs gitleaks unconditionally.
      run: |
        if command -v gitleaks >/dev/null 2>&1; then
          gitleaks protect --staged --no-banner --exit-code 1
        else
          echo "[lefthook] WARNING: gitleaks not installed — secret scan skipped locally."
          echo "[lefthook] Install: https://github.com/gitleaks/gitleaks#installation"
          echo "[lefthook] CI enforces this check unconditionally."
          exit 0
        fi
