# Nightly workflow — %%PROJECT_NAME%% full test matrix
#
# Generated by leap scaffolder. Customize as needed.
#
# Budget: <20 min wall clock.
# Runs: nightly at 03:00 UTC + triggered on release tags + manual dispatch.
# Adds full mutation testing and extended security scanning on top of the PR gate.

name: nightly

on:
  schedule:
    # 03:00 UTC every night.
    - cron: "0 3 * * *"
  push:
    tags:
      - "v*"
  workflow_dispatch:

env:
  TZ: UTC

jobs:
  # ────────────────────────────────────────────────────────────────────────────
  # Full PR-gate suite re-run against main.
  # ────────────────────────────────────────────────────────────────────────────
  pr-gate-full:
    name: pr-gate-full
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0

      # ── TypeScript ───────────────────────────────────────────────────────────
      - name: setup Node
        if: hashFiles('package.json') != ''
        uses: actions/setup-node@v4
        with:
          node-version: "22"

      - name: setup pnpm
        if: hashFiles('pnpm-lock.yaml') != ''
        uses: pnpm/action-setup@v4
        with:
          version: "10"
          run_install: false

      - name: install dependencies (pnpm)
        if: hashFiles('pnpm-lock.yaml') != ''
        run: pnpm install --frozen-lockfile

      - name: install dependencies (npm)
        if: hashFiles('package-lock.json') != ''
        run: npm ci

      - name: install dependencies (yarn)
        if: hashFiles('yarn.lock') != ''
        run: yarn install --frozen-lockfile

      - name: biome check
        if: hashFiles('biome.json') != ''
        run: |
          if command -v pnpm >/dev/null 2>&1 && [ -f pnpm-lock.yaml ]; then
            pnpm exec biome check .
          else
            npx biome check .
          fi

      - name: knip baseline check (strict)
        if: hashFiles('ops/checks/knip-baseline-check.sh') != ''
        run: bash ops/checks/knip-baseline-check.sh --strict

      - name: tsc --noEmit
        if: hashFiles('tsconfig.json') != ''
        run: |
          if [ -f package.json ] && grep -q '"typecheck"' package.json; then
            if command -v pnpm >/dev/null 2>&1 && [ -f pnpm-lock.yaml ]; then
              pnpm typecheck
            else
              npm run typecheck
            fi
          else
            npx tsc --noEmit
          fi

      - name: vitest run with coverage (seed=1337)
        if: hashFiles('vitest.config.ts') != '' || hashFiles('vitest.config.js') != ''
        env:
          TZ: UTC
          VITEST_SEED: "1337"
        run: |
          if command -v pnpm >/dev/null 2>&1 && [ -f pnpm-lock.yaml ]; then
            pnpm exec vitest run --coverage --coverage.reporter=json,lcov \
              --sequence.shuffle --sequence.seed=1337 2>/dev/null || \
              echo "no tests yet"
          else
            npx vitest run --coverage --coverage.reporter=json,lcov \
              --sequence.shuffle --sequence.seed=1337 2>/dev/null || \
              echo "no tests yet"
          fi

      - name: per-file coverage ratchet
        if: hashFiles('ops/checks/coverage-ratchet.js') != ''
        run: |
          if [ -f coverage/coverage-summary.json ]; then
            node ops/checks/coverage-ratchet.js
          else
            echo "coverage ratchet: no data yet"
          fi

      # ── Go ───────────────────────────────────────────────────────────────────
      - name: setup Go
        if: hashFiles('go.mod') != ''
        uses: actions/setup-go@v5
        with:
          go-version: "stable"
          cache: true

      - name: golangci-lint
        if: hashFiles('.golangci.yml') != '' || hashFiles('.golangci.yaml') != ''
        uses: golangci/golangci-lint-action@v6
        with:
          version: latest
          args: --timeout=5m

      - name: go test -race
        if: hashFiles('go.mod') != ''
        run: |
          for modfile in $(find . -name "go.mod" -not -path "*/vendor/*"); do
            dir=$(dirname "$modfile")
            (cd "$dir" && go test -race ./...)
          done

      # ── Python ───────────────────────────────────────────────────────────────
      - name: setup Python
        if: hashFiles('pyproject.toml') != '' || hashFiles('requirements.txt') != ''
        uses: actions/setup-python@v5
        with:
          python-version: "3.12"
          cache: pip

      - name: install Python dependencies
        if: hashFiles('pyproject.toml') != '' || hashFiles('requirements.txt') != ''
        run: |
          pip install --upgrade pip
          if [ -f pyproject.toml ]; then
            pip install -e ".[dev]" 2>/dev/null || pip install -e .
          elif [ -f requirements-dev.txt ]; then
            pip install -r requirements-dev.txt
          elif [ -f requirements.txt ]; then
            pip install -r requirements.txt
          fi

      - name: ruff check + pytest
        if: hashFiles('pyproject.toml') != '' || hashFiles('ruff.toml') != ''
        run: |
          pip install ruff pytest pytest-cov --quiet
          ruff check . && ruff format --check .
          pytest --tb=short --cov --cov-report=json 2>/dev/null || \
            echo "pytest: no tests found"

      # ── Rust ─────────────────────────────────────────────────────────────────
      - name: setup Rust
        if: hashFiles('Cargo.toml') != ''
        uses: dtolnay/rust-toolchain@stable
        with:
          components: rustfmt, clippy

      - name: cargo fmt + clippy + test
        if: hashFiles('Cargo.toml') != ''
        run: |
          cargo fmt -- --check
          cargo clippy -- -D warnings
          cargo test

  # ────────────────────────────────────────────────────────────────────────────
  # Extended security scan (all scanners, higher severity threshold).
  # ────────────────────────────────────────────────────────────────────────────
  security-full:
    name: security-full
    runs-on: ubuntu-latest
    needs: [pr-gate-full]
    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: gitleaks full-history scan
        run: |
          curl -sSfL https://github.com/gitleaks/gitleaks/releases/download/v8.25.1/gitleaks_8.25.1_linux_x64.tar.gz \
            | tar -xz -C /usr/local/bin gitleaks
          gitleaks detect --source . --no-git=false --redact

      - name: setup Node (for lockfile scan)
        if: hashFiles('pnpm-lock.yaml') != '' || hashFiles('package-lock.json') != ''
        uses: actions/setup-node@v4
        with:
          node-version: "22"

      - name: setup pnpm
        if: hashFiles('pnpm-lock.yaml') != ''
        uses: pnpm/action-setup@v4
        with:
          version: "10"
          run_install: false

      - name: install dependencies (pnpm)
        if: hashFiles('pnpm-lock.yaml') != ''
        run: pnpm install --frozen-lockfile

      - name: OSV-Scanner (strict)
        run: |
          curl -sSfL https://github.com/google/osv-scanner/releases/download/v2.0.2/osv-scanner_linux_amd64 \
            -o /usr/local/bin/osv-scanner && chmod +x /usr/local/bin/osv-scanner
          LOCKFILE_ARGS=""
          [ -f pnpm-lock.yaml ]      && LOCKFILE_ARGS="$LOCKFILE_ARGS --lockfile pnpm-lock.yaml"
          [ -f package-lock.json ]   && LOCKFILE_ARGS="$LOCKFILE_ARGS --lockfile package-lock.json"
          [ -f yarn.lock ]           && LOCKFILE_ARGS="$LOCKFILE_ARGS --lockfile yarn.lock"
          [ -f requirements.txt ]    && LOCKFILE_ARGS="$LOCKFILE_ARGS --lockfile requirements.txt"
          [ -f Cargo.lock ]          && LOCKFILE_ARGS="$LOCKFILE_ARGS --lockfile Cargo.lock"
          if [ -n "$LOCKFILE_ARGS" ]; then
            osv-scanner scan $LOCKFILE_ARGS
          else
            osv-scanner scan --recursive .
          fi

      - name: Semgrep with custom rules
        run: |
          pip install semgrep --quiet 2>/dev/null || true
          if command -v semgrep >/dev/null 2>&1; then
            EXTRA_RULES=""
            if [ -f ops/semgrep/custom.yml ]; then
              EXTRA_RULES="--config ops/semgrep/custom.yml"
            fi
            semgrep scan --config p/default $EXTRA_RULES --error \
              --exclude ".next" --exclude "node_modules" --exclude ".turbo" \
              --exclude "target" --exclude "__pycache__" .
          fi

      - name: Trivy filesystem scan (HIGH+ with known fix)
        run: |
          curl -sSfL https://raw.githubusercontent.com/aquasecurity/trivy/main/contrib/install.sh \
            | sh -s -- -b /usr/local/bin v0.62.1
          trivy fs . --severity HIGH,CRITICAL --exit-code 1 \
            --ignore-unfixed \
            --skip-dirs ".next,node_modules,.turbo,target,__pycache__" \
            || { echo "Trivy: HIGH/CRITICAL vulnerabilities with known fix"; exit 1; }

  # ────────────────────────────────────────────────────────────────────────────
  # Full mutation testing (all files, not just changed).
  # ────────────────────────────────────────────────────────────────────────────
  mutation-full:
    name: mutation-full
    runs-on: ubuntu-latest
    needs: [pr-gate-full]
    steps:
      - uses: actions/checkout@v4

      - name: setup Node
        if: hashFiles('package.json') != ''
        uses: actions/setup-node@v4
        with:
          node-version: "22"

      - name: setup pnpm
        if: hashFiles('pnpm-lock.yaml') != ''
        uses: pnpm/action-setup@v4
        with:
          version: "10"
          run_install: false

      - name: install dependencies (pnpm)
        if: hashFiles('pnpm-lock.yaml') != ''
        run: pnpm install --frozen-lockfile

      - name: stryker full mutation run (all TS files)
        if: hashFiles('stryker.config.mjs') != '' || hashFiles('.stryker.config.json') != ''
        run: |
          if command -v pnpm >/dev/null 2>&1 && [ -f pnpm-lock.yaml ]; then
            pnpm exec stryker run
          else
            npx stryker run
          fi

      - name: setup Go
        if: hashFiles('go.mod') != ''
        uses: actions/setup-go@v5
        with:
          go-version: "stable"
          cache: true

      - name: gremlins full Go mutation run
        if: hashFiles('go.mod') != ''
        run: |
          if command -v gremlins >/dev/null 2>&1; then
            find . -name "go.mod" -not -path "*/vendor/*" | while read modfile; do
              dir=$(dirname "$modfile")
              (cd "$dir" && gremlins unleash ./...)
            done
          else
            echo "gremlins not installed — skipping Go mutation testing"
          fi

      - name: setup Python
        if: hashFiles('pyproject.toml') != '' || hashFiles('requirements.txt') != ''
        uses: actions/setup-python@v5
        with:
          python-version: "3.12"
          cache: pip

      - name: mutmut full Python mutation run
        if: hashFiles('pyproject.toml') != '' || hashFiles('setup.cfg') != ''
        run: |
          pip install mutmut --quiet 2>/dev/null || true
          if command -v mutmut >/dev/null 2>&1; then
            mutmut run --no-progress 2>/dev/null || \
              echo "mutmut: no config or no tests found"
          else
            echo "mutmut not available — skipping Python mutation testing"
          fi

  # ────────────────────────────────────────────────────────────────────────────
  # Determinism double-run (extra seeds for nightly confidence).
  # ────────────────────────────────────────────────────────────────────────────
  determinism-nightly:
    name: determinism-nightly
    runs-on: ubuntu-latest
    needs: [security-full, mutation-full]
    steps:
      - uses: actions/checkout@v4

      - name: setup Node
        if: hashFiles('package.json') != ''
        uses: actions/setup-node@v4
        with:
          node-version: "22"

      - name: setup pnpm
        if: hashFiles('pnpm-lock.yaml') != ''
        uses: pnpm/action-setup@v4
        with:
          version: "10"
          run_install: false

      - name: install dependencies (pnpm)
        if: hashFiles('pnpm-lock.yaml') != ''
        run: pnpm install --frozen-lockfile

      - name: vitest run (seed=9999, pass 3)
        if: hashFiles('vitest.config.ts') != '' || hashFiles('vitest.config.js') != ''
        env:
          TZ: UTC
        run: |
          if command -v pnpm >/dev/null 2>&1 && [ -f pnpm-lock.yaml ]; then
            pnpm exec vitest run --sequence.shuffle --sequence.seed=9999 2>/dev/null || \
              echo "determinism pass 3: no tests"
          else
            npx vitest run --sequence.shuffle --sequence.seed=9999 2>/dev/null || \
              echo "determinism pass 3: no tests"
          fi

      - name: vitest run (seed=31415, pass 4)
        if: hashFiles('vitest.config.ts') != '' || hashFiles('vitest.config.js') != ''
        env:
          TZ: UTC
        run: |
          if command -v pnpm >/dev/null 2>&1 && [ -f pnpm-lock.yaml ]; then
            pnpm exec vitest run --sequence.shuffle --sequence.seed=31415 2>/dev/null || \
              echo "determinism pass 4: no tests"
          else
            npx vitest run --sequence.shuffle --sequence.seed=31415 2>/dev/null || \
              echo "determinism pass 4: no tests"
          fi

      - name: setup Go
        if: hashFiles('go.mod') != ''
        uses: actions/setup-go@v5
        with:
          go-version: "stable"
          cache: true

      - name: go test -race -shuffle=9999 (pass 3)
        if: hashFiles('go.mod') != ''
        run: |
          for modfile in $(find . -name "go.mod" -not -path "*/vendor/*"); do
            dir=$(dirname "$modfile")
            (cd "$dir" && go test -race -shuffle=9999 -count=1 ./...)
          done
          echo "go determinism pass 3: PASS"

      - name: go test -race -shuffle=31415 (pass 4)
        if: hashFiles('go.mod') != ''
        run: |
          for modfile in $(find . -name "go.mod" -not -path "*/vendor/*"); do
            dir=$(dirname "$modfile")
            (cd "$dir" && go test -race -shuffle=31415 -count=1 ./...)
          done
          echo "go determinism pass 4: PASS"

      - name: setup Python
        if: hashFiles('pytest.ini') != '' || hashFiles('pyproject.toml') != ''
        uses: actions/setup-python@v5
        with:
          python-version: "3.12"
          cache: pip

      - name: pytest (seed=9999, pass 3)
        if: hashFiles('pytest.ini') != '' || hashFiles('pyproject.toml') != ''
        env:
          TZ: UTC
        run: |
          pip install pytest pytest-randomly --quiet
          pytest --randomly-seed=9999 --tb=short 2>/dev/null || \
            echo "pytest determinism pass 3: no tests"

      - name: pytest (seed=31415, pass 4)
        if: hashFiles('pytest.ini') != '' || hashFiles('pyproject.toml') != ''
        env:
          TZ: UTC
        run: |
          pytest --randomly-seed=31415 --tb=short 2>/dev/null || \
            echo "pytest determinism pass 4: no tests"
