# PR gate workflow — %%PROJECT_NAME%% CI pipeline
#
# Generated by leap scaffolder. Customize as needed.
#
# Stage DAG (fail-fast per stage, parallel within stage):
#   lint → typecheck → unit → security → test-integrity → determinism
#
# Each step uses file-existence guards so this single workflow file works
# for any language stack (TypeScript, Go, Python, Rust).

name: pr-gate

on:
  pull_request:
    branches: [main]
  push:
    branches: [main]

# Cancel in-flight runs for the same PR/branch on new push.
concurrency:
  group: pr-gate-${{ github.ref }}
  cancel-in-progress: true

env:
  # Determinism: all steps run at UTC.
  TZ: UTC

jobs:
  # ────────────────────────────────────────────────────────────────────────────
  # Stage 1: lint (parallel steps within job)
  # ────────────────────────────────────────────────────────────────────────────
  lint:
    name: lint
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0

      # ── TypeScript / JavaScript ──────────────────────────────────────────────
      - name: setup Node
        if: hashFiles('package.json') != ''
        uses: actions/setup-node@v4
        with:
          node-version: "22"

      - name: setup pnpm
        if: hashFiles('pnpm-lock.yaml') != ''
        uses: pnpm/action-setup@v4
        with:
          version: "10"
          run_install: false

      - name: install dependencies (pnpm)
        if: hashFiles('pnpm-lock.yaml') != ''
        run: pnpm install --frozen-lockfile

      - name: install dependencies (npm)
        if: hashFiles('package-lock.json') != ''
        run: npm ci

      - name: install dependencies (yarn)
        if: hashFiles('yarn.lock') != ''
        run: yarn install --frozen-lockfile

      - name: biome check (lint + format)
        if: hashFiles('biome.json') != ''
        run: |
          if command -v pnpm >/dev/null 2>&1 && [ -f pnpm-lock.yaml ]; then
            pnpm exec biome check .
          else
            npx biome check .
          fi

      - name: knip dead-code baseline check
        if: hashFiles('knip.config.ts') != '' || hashFiles('knip.config.js') != ''
        run: |
          if [ -f ops/checks/knip-baseline-check.sh ]; then
            bash ops/checks/knip-baseline-check.sh
          else
            npx knip
          fi

      # ── Go ───────────────────────────────────────────────────────────────────
      - name: setup Go
        if: hashFiles('go.mod') != ''
        uses: actions/setup-go@v5
        with:
          go-version: "stable"
          cache: true

      - name: go mod tidy check
        if: hashFiles('go.mod') != ''
        run: |
          for modfile in $(find . -name "go.mod" -not -path "*/vendor/*"); do
            dir=$(dirname "$modfile")
            echo "checking: $dir"
            (cd "$dir" && go mod tidy -v 2>&1 | tee /tmp/go-tidy-out.txt)
            if [ -s /tmp/go-tidy-out.txt ]; then
              echo "go mod tidy produced output in $dir — unused or missing deps"
              cat /tmp/go-tidy-out.txt
              exit 1
            fi
          done

      - name: golangci-lint
        if: hashFiles('.golangci.yml') != '' || hashFiles('.golangci.yaml') != ''
        uses: golangci/golangci-lint-action@v6
        with:
          version: latest
          args: --timeout=5m

      # ── Python ───────────────────────────────────────────────────────────────
      - name: setup Python
        if: hashFiles('pyproject.toml') != '' || hashFiles('requirements.txt') != ''
        uses: actions/setup-python@v5
        with:
          python-version: "3.12"
          cache: pip

      - name: install Python dependencies
        if: hashFiles('pyproject.toml') != '' || hashFiles('requirements.txt') != ''
        run: |
          pip install --upgrade pip
          if [ -f pyproject.toml ]; then
            pip install -e ".[dev]" 2>/dev/null || pip install -e .
          elif [ -f requirements-dev.txt ]; then
            pip install -r requirements-dev.txt
          elif [ -f requirements.txt ]; then
            pip install -r requirements.txt
          fi

      - name: ruff check (lint + format)
        if: hashFiles('pyproject.toml') != '' || hashFiles('ruff.toml') != '' || hashFiles('.ruff.toml') != ''
        run: |
          pip install ruff --quiet
          ruff check .
          ruff format --check .

      # ── Rust ─────────────────────────────────────────────────────────────────
      - name: setup Rust
        if: hashFiles('Cargo.toml') != ''
        uses: dtolnay/rust-toolchain@stable
        with:
          components: rustfmt, clippy

      - name: cargo fmt check
        if: hashFiles('Cargo.toml') != ''
        run: cargo fmt -- --check

      - name: clippy
        if: hashFiles('Cargo.toml') != ''
        run: cargo clippy -- -D warnings

      # ── Forbidden tokens (all stacks) ─────────────────────────────────────────
      - name: forbidden-tokens check
        if: hashFiles('ops/checks/forbidden-tokens.sh') != ''
        run: bash ops/checks/forbidden-tokens.sh

  # ────────────────────────────────────────────────────────────────────────────
  # Stage 2: typecheck
  # ────────────────────────────────────────────────────────────────────────────
  typecheck:
    name: typecheck
    runs-on: ubuntu-latest
    needs: [lint]
    steps:
      - uses: actions/checkout@v4

      # ── TypeScript ───────────────────────────────────────────────────────────
      - name: setup Node
        if: hashFiles('tsconfig.json') != ''
        uses: actions/setup-node@v4
        with:
          node-version: "22"

      - name: setup pnpm
        if: hashFiles('pnpm-lock.yaml') != ''
        uses: pnpm/action-setup@v4
        with:
          version: "10"
          run_install: false

      - name: install dependencies (pnpm)
        if: hashFiles('pnpm-lock.yaml') != ''
        run: pnpm install --frozen-lockfile

      - name: install dependencies (npm)
        if: hashFiles('package-lock.json') != ''
        run: npm ci

      - name: install dependencies (yarn)
        if: hashFiles('yarn.lock') != ''
        run: yarn install --frozen-lockfile

      - name: tsc --noEmit
        if: hashFiles('tsconfig.json') != ''
        run: |
          if [ -f package.json ] && grep -q '"typecheck"' package.json; then
            if command -v pnpm >/dev/null 2>&1 && [ -f pnpm-lock.yaml ]; then
              pnpm typecheck
            else
              npm run typecheck
            fi
          else
            npx tsc --noEmit
          fi

      # ── Go ───────────────────────────────────────────────────────────────────
      - name: setup Go
        if: hashFiles('go.mod') != ''
        uses: actions/setup-go@v5
        with:
          go-version: "stable"
          cache: true

      - name: go vet
        if: hashFiles('go.mod') != ''
        run: |
          for modfile in $(find . -name "go.mod" -not -path "*/vendor/*"); do
            dir=$(dirname "$modfile")
            echo "go vet: $dir"
            (cd "$dir" && go vet ./...)
          done

      # ── Python ───────────────────────────────────────────────────────────────
      - name: setup Python
        if: hashFiles('pyproject.toml') != '' || hashFiles('requirements.txt') != ''
        uses: actions/setup-python@v5
        with:
          python-version: "3.12"
          cache: pip

      - name: install Python dependencies
        if: hashFiles('pyproject.toml') != '' || hashFiles('requirements.txt') != ''
        run: |
          pip install --upgrade pip
          if [ -f pyproject.toml ]; then
            pip install -e ".[dev]" 2>/dev/null || pip install -e .
          elif [ -f requirements-dev.txt ]; then
            pip install -r requirements-dev.txt
          elif [ -f requirements.txt ]; then
            pip install -r requirements.txt
          fi

      - name: mypy
        if: hashFiles('pyproject.toml') != '' || hashFiles('mypy.ini') != '' || hashFiles('.mypy.ini') != ''
        run: |
          pip install mypy --quiet
          mypy . --ignore-missing-imports 2>/dev/null || \
            echo "mypy: no typed sources found or config missing — skipping"

  # ────────────────────────────────────────────────────────────────────────────
  # Stage 3: unit tests + coverage ratchet
  # ────────────────────────────────────────────────────────────────────────────
  unit:
    name: unit
    runs-on: ubuntu-latest
    needs: [typecheck]
    env:
      TZ: UTC
      VITEST_SEED: "42"

    steps:
      - uses: actions/checkout@v4

      # ── TypeScript ───────────────────────────────────────────────────────────
      - name: setup Node
        if: hashFiles('package.json') != ''
        uses: actions/setup-node@v4
        with:
          node-version: "22"

      - name: setup pnpm
        if: hashFiles('pnpm-lock.yaml') != ''
        uses: pnpm/action-setup@v4
        with:
          version: "10"
          run_install: false

      - name: install dependencies (pnpm)
        if: hashFiles('pnpm-lock.yaml') != ''
        run: pnpm install --frozen-lockfile

      - name: install dependencies (npm)
        if: hashFiles('package-lock.json') != ''
        run: npm ci

      - name: install dependencies (yarn)
        if: hashFiles('yarn.lock') != ''
        run: yarn install --frozen-lockfile

      - name: vitest run
        if: hashFiles('vitest.config.ts') != '' || hashFiles('vitest.config.js') != ''
        run: |
          if [ -f package.json ] && grep -q '"test"' package.json; then
            if command -v pnpm >/dev/null 2>&1 && [ -f pnpm-lock.yaml ]; then
              pnpm test
            else
              npm test
            fi
          else
            npx vitest run
          fi

      - name: jest run
        if: hashFiles('jest.config.ts') != '' || hashFiles('jest.config.js') != ''
        run: |
          if command -v pnpm >/dev/null 2>&1 && [ -f pnpm-lock.yaml ]; then
            pnpm exec jest
          else
            npx jest
          fi

      # ── Go ───────────────────────────────────────────────────────────────────
      - name: setup Go
        if: hashFiles('go.mod') != ''
        uses: actions/setup-go@v5
        with:
          go-version: "stable"
          cache: true

      - name: go test -race
        if: hashFiles('go.mod') != ''
        run: |
          for modfile in $(find . -name "go.mod" -not -path "*/vendor/*"); do
            dir=$(dirname "$modfile")
            echo "go test: $dir"
            (cd "$dir" && go test -race ./...)
          done

      # ── Python ───────────────────────────────────────────────────────────────
      - name: setup Python
        if: hashFiles('pyproject.toml') != '' || hashFiles('requirements.txt') != ''
        uses: actions/setup-python@v5
        with:
          python-version: "3.12"
          cache: pip

      - name: install Python dependencies
        if: hashFiles('pyproject.toml') != '' || hashFiles('requirements.txt') != ''
        run: |
          pip install --upgrade pip
          if [ -f pyproject.toml ]; then
            pip install -e ".[dev]" 2>/dev/null || pip install -e .
          elif [ -f requirements-dev.txt ]; then
            pip install -r requirements-dev.txt
          elif [ -f requirements.txt ]; then
            pip install -r requirements.txt
          fi

      - name: pytest
        if: hashFiles('pytest.ini') != '' || hashFiles('pyproject.toml') != '' || hashFiles('setup.cfg') != ''
        run: |
          pip install pytest pytest-cov --quiet
          pytest --tb=short --cov --cov-report=json 2>/dev/null || \
            pytest --tb=short 2>/dev/null || \
            echo "pytest: no tests found or config missing"

      # ── Rust ─────────────────────────────────────────────────────────────────
      - name: setup Rust
        if: hashFiles('Cargo.toml') != ''
        uses: dtolnay/rust-toolchain@stable

      - name: cargo test
        if: hashFiles('Cargo.toml') != ''
        run: cargo test

      # ── Coverage ratchet (runs after any test step) ───────────────────────────
      - name: per-file coverage ratchet
        if: hashFiles('ops/checks/coverage-ratchet.js') != ''
        run: |
          if [ -f coverage/coverage-summary.json ]; then
            node ops/checks/coverage-ratchet.js
          else
            echo "no coverage data — skipping ratchet"
          fi

  # ────────────────────────────────────────────────────────────────────────────
  # Stage 4: security (parallel with typecheck, depends on lint)
  # ────────────────────────────────────────────────────────────────────────────
  security:
    name: security
    runs-on: ubuntu-latest
    needs: [lint]
    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: gitleaks full-history scan
        run: |
          curl -sSfL https://github.com/gitleaks/gitleaks/releases/download/v8.25.1/gitleaks_8.25.1_linux_x64.tar.gz \
            | tar -xz -C /usr/local/bin gitleaks
          gitleaks detect --source . --no-git=false --redact \
            || { echo "gitleaks: secret detected — block"; exit 1; }

      - name: setup Node (for lockfile scan)
        if: hashFiles('pnpm-lock.yaml') != '' || hashFiles('package-lock.json') != ''
        uses: actions/setup-node@v4
        with:
          node-version: "22"

      - name: setup pnpm
        if: hashFiles('pnpm-lock.yaml') != ''
        uses: pnpm/action-setup@v4
        with:
          version: "10"
          run_install: false

      - name: install dependencies (pnpm)
        if: hashFiles('pnpm-lock.yaml') != ''
        run: pnpm install --frozen-lockfile

      - name: OSV-Scanner
        run: |
          curl -sSfL https://github.com/google/osv-scanner/releases/download/v2.0.2/osv-scanner_linux_amd64 \
            -o /usr/local/bin/osv-scanner && chmod +x /usr/local/bin/osv-scanner
          # Scan whichever lockfiles are present.
          LOCKFILE_ARGS=""
          [ -f pnpm-lock.yaml ]      && LOCKFILE_ARGS="$LOCKFILE_ARGS --lockfile pnpm-lock.yaml"
          [ -f package-lock.json ]   && LOCKFILE_ARGS="$LOCKFILE_ARGS --lockfile package-lock.json"
          [ -f yarn.lock ]           && LOCKFILE_ARGS="$LOCKFILE_ARGS --lockfile yarn.lock"
          [ -f requirements.txt ]    && LOCKFILE_ARGS="$LOCKFILE_ARGS --lockfile requirements.txt"
          [ -f Cargo.lock ]          && LOCKFILE_ARGS="$LOCKFILE_ARGS --lockfile Cargo.lock"
          if [ -n "$LOCKFILE_ARGS" ]; then
            osv-scanner scan $LOCKFILE_ARGS \
              || { echo "OSV-Scanner: vulnerable dependencies detected"; exit 1; }
          else
            echo "no lockfiles found — running directory scan"
            osv-scanner scan --recursive . \
              || { echo "OSV-Scanner: vulnerable dependencies detected"; exit 1; }
          fi

      - name: Semgrep
        run: |
          pip install semgrep --quiet 2>/dev/null || true
          if command -v semgrep >/dev/null 2>&1; then
            EXTRA_RULES=""
            if [ -f ops/semgrep/custom.yml ]; then
              EXTRA_RULES="--config ops/semgrep/custom.yml"
            fi
            semgrep scan --config p/default $EXTRA_RULES --error \
              --exclude ".next" --exclude "node_modules" --exclude ".turbo" \
              --exclude "target" --exclude "__pycache__" \
              . || { echo "Semgrep: violations found"; exit 1; }
          else
            echo "semgrep install failed — skipping"
          fi

  # ────────────────────────────────────────────────────────────────────────────
  # Stage 5: test-integrity (depends on unit)
  # ────────────────────────────────────────────────────────────────────────────
  test-integrity:
    name: test-integrity
    runs-on: ubuntu-latest
    needs: [unit, security]
    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: setup Node
        if: hashFiles('package.json') != ''
        uses: actions/setup-node@v4
        with:
          node-version: "22"

      - name: setup pnpm
        if: hashFiles('pnpm-lock.yaml') != ''
        uses: pnpm/action-setup@v4
        with:
          version: "10"
          run_install: false

      - name: install dependencies (pnpm)
        if: hashFiles('pnpm-lock.yaml') != ''
        run: pnpm install --frozen-lockfile

      - name: install dependencies (npm)
        if: hashFiles('package-lock.json') != ''
        run: npm ci

      - name: test-deletion detector
        run: |
          git fetch origin main --depth=1 2>/dev/null || true
          BASE=$(git merge-base HEAD origin/main 2>/dev/null || echo "HEAD~1")
          HEAD="${{ github.sha }}"
          echo "test-deletion detector: BASE=$BASE HEAD=$HEAD"
          TEST_LINES_REMOVED=$(git diff "$BASE" "$HEAD" -- "*.test.*" "*.spec.*" \
            | grep "^-" | grep -v "^---" | wc -l || echo 0)
          TEST_LINES_ADDED=$(git diff "$BASE" "$HEAD" -- "*.test.*" "*.spec.*" \
            | grep "^+" | grep -v "^+++" | wc -l || echo 0)
          echo "test lines: removed=$TEST_LINES_REMOVED added=$TEST_LINES_ADDED"
          if [ "$TEST_LINES_REMOVED" -gt "$TEST_LINES_ADDED" ]; then
            echo "ERROR: net test line deletion detected ($TEST_LINES_REMOVED removed vs $TEST_LINES_ADDED added)"
            exit 1
          fi
          echo "test-deletion check: OK"

      - name: assertion-count ratchet
        if: hashFiles('ops/checks/assertion-count-ratchet.js') != ''
        run: |
          if find . \( -name "*.test.ts" -o -name "*.test.tsx" -o -name "*.spec.ts" \) \
               2>/dev/null | grep -qv "node_modules"; then
            node ops/checks/assertion-count-ratchet.js
          else
            echo "no TypeScript test files — skipping assertion-count ratchet"
          fi

      - name: waiver-expiry check
        if: hashFiles('docs/waivers.yaml') != ''
        run: |
          if [ -f ops/checks/waiver-expiry-check.sh ]; then
            bash ops/checks/waiver-expiry-check.sh
          else
            echo "waiver-expiry check script not found — skipping"
          fi

      # Stryker mutation testing (TypeScript — changed files only).
      - name: stryker mutation testing (changed TS files)
        if: hashFiles('stryker.config.mjs') != '' || hashFiles('.stryker.config.json') != ''
        run: |
          BASE=$(git merge-base HEAD origin/main 2>/dev/null || echo "HEAD~1")
          CHANGED_TS=$(git diff --name-only "$BASE" "${{ github.sha }}" \
            | grep -E "\.(ts|tsx)$" | grep -v "node_modules" | grep -v "\.d\.ts$" || true)
          if [ -z "$CHANGED_TS" ]; then
            echo "no changed TS files — skipping Stryker"
            exit 0
          fi
          echo "changed TS files:"
          echo "$CHANGED_TS"
          if command -v pnpm >/dev/null 2>&1 && [ -f pnpm-lock.yaml ]; then
            pnpm exec stryker run
          else
            npx stryker run
          fi

      # gremlins.go mutation testing (Go — changed files only).
      - name: setup Go
        if: hashFiles('go.mod') != ''
        uses: actions/setup-go@v5
        with:
          go-version: "stable"
          cache: true

      - name: gremlins mutation testing (changed Go files)
        if: hashFiles('go.mod') != ''
        run: |
          BASE=$(git merge-base HEAD origin/main 2>/dev/null || echo "HEAD~1")
          CHANGED_GO=$(git diff --name-only "$BASE" "${{ github.sha }}" \
            | grep "\.go$" | grep -v "vendor/" || true)
          if [ -z "$CHANGED_GO" ]; then
            echo "no changed Go files — skipping gremlins"
            exit 0
          fi
          if command -v gremlins >/dev/null 2>&1; then
            echo "$CHANGED_GO" | xargs gremlins unleash
          else
            echo "gremlins not installed — skipping Go mutation testing"
          fi

  # ────────────────────────────────────────────────────────────────────────────
  # Stage 6: determinism (double-run with different seeds)
  # ────────────────────────────────────────────────────────────────────────────
  determinism:
    name: determinism
    runs-on: ubuntu-latest
    needs: [test-integrity]
    steps:
      - uses: actions/checkout@v4

      # ── TypeScript ───────────────────────────────────────────────────────────
      - name: setup Node
        if: hashFiles('package.json') != ''
        uses: actions/setup-node@v4
        with:
          node-version: "22"

      - name: setup pnpm
        if: hashFiles('pnpm-lock.yaml') != ''
        uses: pnpm/action-setup@v4
        with:
          version: "10"
          run_install: false

      - name: install dependencies (pnpm)
        if: hashFiles('pnpm-lock.yaml') != ''
        run: pnpm install --frozen-lockfile

      - name: install dependencies (npm)
        if: hashFiles('package-lock.json') != ''
        run: npm ci

      - name: vitest run (seed=1337, pass 1)
        if: hashFiles('vitest.config.ts') != '' || hashFiles('vitest.config.js') != ''
        env:
          TZ: UTC
          VITEST_SEED: "1337"
        run: |
          if command -v pnpm >/dev/null 2>&1 && [ -f pnpm-lock.yaml ]; then
            pnpm test
          else
            npx vitest run --sequence.shuffle --sequence.seed=1337
          fi

      - name: vitest run (seed=2718, pass 2)
        if: hashFiles('vitest.config.ts') != '' || hashFiles('vitest.config.js') != ''
        env:
          TZ: UTC
          VITEST_SEED: "2718"
        run: |
          if command -v pnpm >/dev/null 2>&1 && [ -f pnpm-lock.yaml ]; then
            pnpm test
          else
            npx vitest run --sequence.shuffle --sequence.seed=2718
          fi

      # ── Go ───────────────────────────────────────────────────────────────────
      - name: setup Go
        if: hashFiles('go.mod') != ''
        uses: actions/setup-go@v5
        with:
          go-version: "stable"
          cache: true

      - name: go test -race -shuffle=1337 (pass 1)
        if: hashFiles('go.mod') != ''
        run: |
          for modfile in $(find . -name "go.mod" -not -path "*/vendor/*"); do
            dir=$(dirname "$modfile")
            (cd "$dir" && go test -race -shuffle=1337 -count=1 ./...)
          done
          echo "go determinism pass 1: PASS"

      - name: go test -race -shuffle=2718 (pass 2)
        if: hashFiles('go.mod') != ''
        run: |
          for modfile in $(find . -name "go.mod" -not -path "*/vendor/*"); do
            dir=$(dirname "$modfile")
            (cd "$dir" && go test -race -shuffle=2718 -count=1 ./...)
          done
          echo "go determinism pass 2: PASS"

      # ── Python ───────────────────────────────────────────────────────────────
      - name: setup Python
        if: hashFiles('pytest.ini') != '' || hashFiles('pyproject.toml') != ''
        uses: actions/setup-python@v5
        with:
          python-version: "3.12"
          cache: pip

      - name: install Python dependencies
        if: hashFiles('pytest.ini') != '' || hashFiles('pyproject.toml') != ''
        run: |
          pip install --upgrade pip pytest
          if [ -f pyproject.toml ]; then
            pip install -e ".[dev]" 2>/dev/null || pip install -e .
          elif [ -f requirements-dev.txt ]; then
            pip install -r requirements-dev.txt
          elif [ -f requirements.txt ]; then
            pip install -r requirements.txt
          fi

      - name: pytest (seed=1337, pass 1)
        if: hashFiles('pytest.ini') != '' || hashFiles('pyproject.toml') != ''
        env:
          TZ: UTC
        run: |
          pip install pytest-randomly --quiet
          pytest --randomly-seed=1337 --tb=short 2>/dev/null || \
            echo "pytest determinism pass 1: no tests or config missing"

      - name: pytest (seed=2718, pass 2)
        if: hashFiles('pytest.ini') != '' || hashFiles('pyproject.toml') != ''
        env:
          TZ: UTC
        run: |
          pytest --randomly-seed=2718 --tb=short 2>/dev/null || \
            echo "pytest determinism pass 2: no tests or config missing"

      # ── Rust ─────────────────────────────────────────────────────────────────
      - name: setup Rust
        if: hashFiles('Cargo.toml') != ''
        uses: dtolnay/rust-toolchain@stable

      - name: cargo test (pass 1)
        if: hashFiles('Cargo.toml') != ''
        run: cargo test

      - name: cargo test (pass 2)
        if: hashFiles('Cargo.toml') != ''
        run: cargo test
